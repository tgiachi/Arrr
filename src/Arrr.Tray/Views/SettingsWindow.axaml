<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Arrr.Tray.ViewModels"
        x:Class="Arrr.Tray.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Arrr Tray — Settings"
        Width="420" Height="265"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

  <StackPanel Margin="16" Spacing="12">

    <StackPanel Spacing="4">
      <TextBlock Text="Server URL" FontWeight="SemiBold"/>
      <TextBox Text="{Binding ServerUrl}" PlaceholderText="http://localhost:5150"/>
    </StackPanel>

    <StackPanel Spacing="4">
      <TextBlock Text="API Key" FontWeight="SemiBold"/>
      <TextBox Text="{Binding ApiKey}" PasswordChar="•" PlaceholderText="leave empty if not set"/>
    </StackPanel>

    <StackPanel Spacing="4">
      <TextBlock Text="gRPC URL (port+1 for h2c)" FontWeight="SemiBold"/>
      <TextBox Text="{Binding GrpcUrl}" PlaceholderText="http://localhost:5151"/>
    </StackPanel>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="Cancel" Command="{Binding CancelCommand}"/>
      <Button Content="Save" Command="{Binding SaveCommand}" Classes="accent"/>
    </StackPanel>

  </StackPanel>
</Window>
