<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <AssemblyName>Arrr.Sink.Telegram</AssemblyName>
        <RootNamespace>Arrr.Sink.Telegram</RootNamespace>

        <PackageId>Arrr.Sink.Telegram</PackageId>
        <Version>1.7.0</Version>
        <Authors>Tom</Authors>
        <Company>orivega.io</Company>
        <Description>Telegram Bot sink for Arrr — delivers notifications to a Telegram chat or group via Bot API.</Description>
        <PackageTags>arrr;arrr-sink;sink;telegram;bot;notifications;linux</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/tgiachi/Arrr</PackageProjectUrl>
        <RepositoryUrl>https://github.com/tgiachi/Arrr</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageIcon>arr_logo.png</PackageIcon>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Arrr.Core" Version="1.6.0" />
        <PackageReference Include="Telegram.Bot" Version="22.9.6.1" />
    </ItemGroup>

    <ItemGroup>
        <None Include="../../assets/arr_logo.png" Pack="true" PackagePath="\"/>
    </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="icon.png" LogicalName="icon.png" />
  </ItemGroup>
</Project>
