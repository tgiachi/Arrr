{
  "branches": [
    "main"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "./scripts/semantic-release-prepare.sh ${nextRelease.version}",
        "publishCmd": "./scripts/build_package.sh ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "src/**/*.csproj",
          "templates/Arrr.Templates.csproj",
          "plugins/**/*.csproj",
          "ui/package.json"
        ],
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "releasedLabels": false,
        "assets": [
          { "path": "dist/*.deb",         "label": "Debian package (amd64)" },
          { "path": "dist/*.rpm",         "label": "RPM package (x86_64)" },
          { "path": "dist/*.pkg.tar.zst", "label": "Arch Linux package (x86_64)" },
          { "path": "dist/*.pkg.tar.zst.sig", "label": "Arch Linux package signature" }
        ]
      }
    ]
  ]
}
