{
  "branches": [
    "main"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "./scripts/semantic-release-prepare.sh ${nextRelease.version}",
        "publishCmd": "./scripts/build_package.sh ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "src/**/*.csproj",
          "templates/Arrr.Templates.csproj",
          "plugins/**/*.csproj",
          "ui/package.json"
        ],
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "releasedLabels": false,
        "assets": [
          { "path": "dist/arrr_*.deb",                "label": "arrr — Debian package (amd64)" },
          { "path": "dist/arrr-[0-9]*.rpm",           "label": "arrr — RPM package (x86_64)" },
          { "path": "dist/arrr-[0-9]*.pkg.tar.zst",   "label": "arrr — Arch Linux package (x86_64)" },
          { "path": "dist/arrr-[0-9]*.pkg.tar.zst.sig", "label": "arrr — Arch Linux package signature" },
          { "path": "dist/arrr-tray_*.deb",                "label": "arrr-tray — Debian package (amd64)" },
          { "path": "dist/arrr-tray-*.rpm",                "label": "arrr-tray — RPM package (x86_64)" },
          { "path": "dist/arrr-tray-*.pkg.tar.zst",        "label": "arrr-tray — Arch Linux package (x86_64)" },
          { "path": "dist/arrr-tray-*.pkg.tar.zst.sig",    "label": "arrr-tray — Arch Linux package signature" }
        ]
      }
    ]
  ]
}
