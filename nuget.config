<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="local" value="./local-packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <!-- Arrr.Core is resolved exclusively from the local feed.
       Run scripts/pack-dev.sh to populate it before building plugins. -->
  <packageSourceMapping>
    <packageSource key="local">
      <package pattern="Arrr.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
